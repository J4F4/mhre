# ===== Alhubishi Real Estate - Environment Variables =====

# Public site URL (used for SEO / sitemap / canonical / schema)
NEXT_PUBLIC_SITE_URL=https://alhubishi.com

# Map provider tiles (optional).
# By default the map uses free OpenStreetMap tiles and requires NO key.
# To use Mapbox tiles instead, provide a token and style URL.
NEXT_PUBLIC_MAP_PROVIDER=osm            # osm | mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_MAPBOX_STYLE=mapbox/streets-v12

# Google Maps embed (office location on the contact page).
# Leave empty to use a keyless embed fallback.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=

# Admin dashboard password (protects /admin write operations).
# Change this before deploying to production.
ADMIN_PASSWORD=alhubishi-admin

# Optional: remote data sources to import properties from (see lib/import.ts)
DATA_SOURCE_URL_1=https://tr.ee/vIOj5a
DATA_SOURCE_URL_2=https://tr.ee/cxZWr8
